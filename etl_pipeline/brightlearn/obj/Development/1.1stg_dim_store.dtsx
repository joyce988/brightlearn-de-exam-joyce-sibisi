          SQLTask:SqlStatementSource="create or alter  procedure [dbo].[sp_clean_dim_store] as&#xA;&#xA;begin&#xA;&#xA;if object_id ('[stg_brightlearn_store].[dbo].[clean_dim_store]') is not null&#xA;    drop table [stg_brightlearn_store].[dbo].[clean_dim_store];&#xA;&#xA; &#xA;&#xA;&#xA;    CREATE TABLE [stg_brightlearn_store].[dbo].[clean_dim_store]&#xA;    ([storeID] INT IDENTITY(1,1) PRIMARY KEY,&#xA;    [cashier_name] [varchar](50) NULL,&#xA;    [store_name] [varchar](50) NULL,&#xA;&#x9;[store_city] [varchar](50) NULL,&#xA;&#x9;[store_province] [varchar](50) NULL,&#xA;&#x9;[store_region] [varchar](50) NULL,&#xA;&#x9;[store_manager] [varchar](50) NULL,&#xA;    [load_date] DATETIME DEFAULT GETDATE()&#xA;    );&#xA;&#xA; &#xA;&#xA;    truncate table [stg_brightlearn_store].[dbo].[clean_dim_store];&#xA;&#xA;    INSERT INTO [stg_brightlearn_store].[dbo].[clean_dim_store]( cashier_name,store_name, &#xA;    store_city, store_province,  store_region, store_manager )&#xA;SELECT DISTINCT&#xA;     cashier_name,store_name, &#xA;    store_city, store_province,  store_region, store_manager&#xA;FROM [stg_brightlearn_store].[dbo].[stg_dim_store]&#xA;&#xA;    --view data in table&#xA;    select * from [stg_brightlearn_store].[dbo].[stg_dim_store]&#xA;&#xA;&#xA;    end;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
